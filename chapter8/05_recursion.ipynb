     "output_type": "stream",
     "text": [
      "The factorial of 5 is: 120\n"
     ]
    }
   ],
   "source": [
    "def factorial(n):\n",
    "    if n == 0 or n == 1:\n",
    "        return 1\n",
    "    return n * factorial(n-1) \n",
    "\n",
    "n = int(input(\"Enter a number to find its factorial: \"))\n",
    "result = factorial(n)\n",
    "print(f\"The factorial of {n} is: {result}\")"
   ]
  },
