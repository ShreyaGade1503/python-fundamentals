   "source": [
    "f = open(\"text.txt\")\n",
    "\n",
    "print(f.read())\n",
    "\n",
    "f.close()"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "9d5ca161",
   "metadata": {},
   "source": [
    "this same can be written using with"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "fd143f29",
   "metadata": {},
   "outputs": [],
   "source": [
    "with open(\"text.txt\") as f:\n",
    "    print(f.read())"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "28439b63",
   "metadata": {},
   "source": [
    "you don't  have to close the file after using with statement"
   ]
